{
  "crons": [
    {
      "path": "/api/keepalive",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/withings/sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/google-health/sync",
      "schedule": "30 6 * * *"
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
